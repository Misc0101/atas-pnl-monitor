{
  "name": "atas-pnl-monitor",
  "version": "1.1.1",
  "description": "ATAS 实时盈亏曲线监控工具",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "icon": "node scripts/gen-icon.js",
    "build": "electron-builder"
  },
  "dependencies": {
    "echarts": "^5.5.0"
  },
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.atas.pnlmonitor",
    "productName": "ATAS PnL Monitor",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "ATAS PnL Monitor"
    },
    "portable": {
      "artifactName": "ATAS-PnL-Monitor-portable.exe"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "node_modules/**/*",
      "!node_modules/electron-builder/**/*",
      "!node_modules/.bin/**/*"
    ]
  }
}
